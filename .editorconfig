root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,json,md,yml,yaml,css,html}]
indent_style = space
indent_size = 2

[*.{kt,kts,swift,java}]
indent_style = space
indent_size = 4

[*.{png,jpg,jpeg,webp,gif,jar,keystore}]
insert_final_newline = false
trim_trailing_whitespace = false
